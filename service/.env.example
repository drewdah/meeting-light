# Copy this to .env and fill in your values.
# docker-compose passes everything here as environment variables to the service.

# ── Device ────────────────────────────────────────────────────────────────────
# BLE MAC address of your ESP32 (shown on the "Waiting to Connect" screen at boot)
ESP32_MAC_ADDRESS=AA:BB:CC:DD:EE:FF

# ── Calendar provider ─────────────────────────────────────────────────────────
CALENDAR_PROVIDER=microsoft

# Microsoft 365 / Outlook (when CALENDAR_PROVIDER=microsoft)
# Public-client app ID from Azure — see README "One-time provider setup"
MS_GRAPH_CLIENT_ID=67fe50d7-c7e7-433c-b336-1238a8e8ceae
MS_GRAPH_TENANT_ID=12649e22-1866-4f6f-a9b8-53fde1306cfd

# Google Calendar (when CALENDAR_PROVIDER=google)
# Client ID and secret from Google Cloud — see README "One-time provider setup"
# Note: calendar.readonly is a sensitive scope; see README for the 100-user / 7-day
# refresh-token limit that applies until Google verifies the app.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Schedule ──────────────────────────────────────────────────────────────────
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
TIMEZONE=America/New_York
