# Copy this to .env and fill in your values

# BLE — MAC address of your ESP32 (shown in serial monitor on boot, or find via BLE scanner)
ESP32_MAC_ADDRESS=AA:BB:CC:DD:EE:FF

# Calendar provider: "microsoft" (default) or "google"
CALENDAR_PROVIDER=microsoft

# Microsoft 365 / Outlook — create an app registration at portal.azure.com
# Required when CALENDAR_PROVIDER=microsoft
MS_GRAPH_CLIENT_ID=your-client-id-here
MS_GRAPH_TENANT_ID=common

# Google Calendar — create OAuth2 credentials at console.cloud.google.com
# Required when CALENDAR_PROVIDER=google
# App type must be "TV and Limited Input devices" for device flow
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Schedule
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
TIMEZONE=America/New_York

# Polling interval (seconds)
GRAPH_POLL_INTERVAL_SECONDS=60
