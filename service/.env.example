# Copy this to .env and fill in your values

# BLE — MAC address of your ESP32 (shown in serial monitor on boot, or find via BLE scanner)
ESP32_MAC_ADDRESS=AA:BB:CC:DD:EE:FF

# Microsoft Graph — create an app registration at portal.azure.com
MS_GRAPH_CLIENT_ID=your-client-id-here
MS_GRAPH_TENANT_ID=common

# Schedule
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
TIMEZONE=America/New_York

# Polling interval (seconds)
GRAPH_POLL_INTERVAL_SECONDS=60
